@page "/chess"
@inject IGameStateService GameService
@implements IDisposable
@using Games.Chess.Models
@using Games.Chess.Logic

<PageTitle>Chess</PageTitle>
<h1>Chess</h1>

<div class="game-container">
@if (game != null && game.Board != null)
{
    <div class="game-info">
        <span>Turn: <strong>@(game.IsWhiteTurn ? "White ♔" : "Black ♚")</strong></span>
        @if (aiThinking)
        {
            <span class="ai-status">AI thinking...</span>
        }
        @if (game.HasAI)
        {
            <span>You: <strong>@(game.AIIsWhite ? "Black ♚" : "White ♔")</strong></span>
        }
    </div>

    @if (game.IsGameOver && game.Winner.HasValue)
    {
        <div class="game-message winner">
            @(game.Winner == 1 ? "White ♔ Wins!" : "Black ♚ Wins!")
        </div>
    }
    else if (game.IsGameOver && !game.Winner.HasValue)
    {
        <div class="game-message draw">Draw!</div>
    }

    <div class="chess-board">
        @for (int r = 0; r < 8; r++)
        {
            var row = r;
            <div class="chess-row">
                @for (int c = 0; c < 8; c++)
                {
                    var col = c;
                    var piece = game.GetPiece(row, col);
                    var isLight = (row + col) % 2 == 0;
                    var isSelected = selectedRow == row && selectedCol == col;
                    var isLastMove = (lastMove.FromRow == row && lastMove.FromCol == col) ||
                                     (lastMove.ToRow == row && lastMove.ToCol == col);
                    var isValidTarget = validMoves.Any(m => m.Row == row && m.Col == col);
                    
                    <div class="chess-cell @(isLight ? "light" : "dark") @(isSelected ? "selected" : "") @(isLastMove ? "last-move" : "") @(isValidTarget ? "valid-move" : "")"
                         @onclick="() => SelectSquare(row, col)">
                        @if (piece != null && piece.Type != PieceType.None)
                        {
                            <span class="chess-piece">@GetPieceSymbol(piece)</span>
                        }
                        @if (isValidTarget && piece == null)
                        {
                            <div class="valid-move-dot"></div>
                        }
                    </div>
                }
            </div>
        }
    </div>
    
    <div class="game-controls">
        @if (!game.IsPlaying)
        {
            <button class="btn btn-primary" @onclick="StartGame">Start Game</button>
        }
        else
        {
            <button class="btn btn-secondary" @onclick="TogglePause">@(_isPaused ? "Resume" : "Pause")</button>
            <button class="btn btn-danger" @onclick="ResetGame">Reset</button>
        }
    </div>

    <div class="mode-selector">
        <span>Game Mode:</span>
        <button class="mode-btn @(!useAI ? "active" : "")" @onclick="@(() => SetMode(false))">2 Players</button>
        <button class="mode-btn @(useAI ? "active" : "")" @onclick="@(() => SetMode(true))">vs AI</button>
    </div>

    @if (useAI)
    {
        <div class="difficulty-selector">
            <span>AI Level:</span>
            <button class="diff-btn @(_aiDepth == 1 ? "active" : "")" @onclick="@(() => SetDifficulty(1))">Easy</button>
            <button class="diff-btn @(_aiDepth == 2 ? "active" : "")" @onclick="@(() => SetDifficulty(2))">Normal</button>
            <button class="diff-btn @(_aiDepth == 3 ? "active" : "")" @onclick="@(() => SetDifficulty(3))">Hard</button>
        </div>
    }
}
else
{
    <p>Loading...</p>
}
</div>

@code {
    private ChessGame? game;
    private int selectedRow = -1;
    private int selectedCol = -1;
    private bool _isPaused = false;
    private bool useAI = true;
    private int _aiDepth = 2;
    private bool aiThinking = false;
    private bool _aiFirstMoveDone = false;
    private (int FromRow, int FromCol, int ToRow, int ToCol) lastMove = (-1, -1, -1, -1);
    private List<(int Row, int Col)> validMoves = new();
    
    protected override void OnInitialized()
    {
        CreateGame();
        GameService.OnStateChanged += HandleStateChanged;
    }
    
    private void CreateGame()
    {
        if (useAI)
        {
            var logic = new ChessLogic(useAI: true, aiDepth: _aiDepth);
            game = new ChessGame(logic);
        }
        else
        {
            var logic = new ChessLogic();
            game = new ChessGame(logic);
        }
        lastMove = (-1, -1, -1, -1);
        validMoves.Clear();
        selectedRow = -1;
        selectedCol = -1;
        GameService.StartGame(game);
        game.StartGame();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_aiFirstMoveDone && game != null && game.HasAI && game.IsPlaying)
        {
            // Wait a bit for state to settle
            await Task.Delay(500);
            
            if (game.IsAITurn())
            {
                _aiFirstMoveDone = true;
                aiThinking = true;
                StateHasChanged();
                
                await InvokeAsync(() =>
                {
                    if (game != null)
                    {
                        var result = game.MakeAIMoveWithPosition();
                        if (result.HasValue && result.Value.success)
                        {
                            lastMove = (result.Value.fromRow, result.Value.fromCol, result.Value.toRow, result.Value.toCol);
                        }
                    }
                    aiThinking = false;
                    StateHasChanged();
                });
            }
        }
        
        await base.OnAfterRenderAsync(firstRender);
    }
    
    private void HandleStateChanged() => InvokeAsync(StateHasChanged);
    
    private string GetPieceSymbol(ChessPiece piece) => piece switch
    {
        { Type: PieceType.King, Color: PieceColor.White } => "♔",
        { Type: PieceType.Queen, Color: PieceColor.White } => "♕",
        { Type: PieceType.Rook, Color: PieceColor.White } => "♖",
        { Type: PieceType.Bishop, Color: PieceColor.White } => "♗",
        { Type: PieceType.Knight, Color: PieceColor.White } => "♘",
        { Type: PieceType.Pawn, Color: PieceColor.White } => "♙",
        { Type: PieceType.King, Color: PieceColor.Black } => "♚",
        { Type: PieceType.Queen, Color: PieceColor.Black } => "♛",
        { Type: PieceType.Rook, Color: PieceColor.Black } => "♜",
        { Type: PieceType.Bishop, Color: PieceColor.Black } => "♝",
        { Type: PieceType.Knight, Color: PieceColor.Black } => "♞",
        { Type: PieceType.Pawn, Color: PieceColor.Black } => "♟",
        _ => ""
    };
    
    private void SelectSquare(int row, int col)
    {
        if (game == null || !game.IsPlaying || _isPaused) return;
        
        // If it's AI's turn, ignore
        if (game.HasAI && game.IsAITurn()) return;
        
        if (row < 0 || row >= 8 || col < 0 || col >= 8) return;
        
        var piece = game.GetPiece(row, col);
        var myColor = game.IsWhiteTurn ? PieceColor.White : PieceColor.Black;
        
        // If a piece is already selected, try to move
        if (selectedRow >= 0)
        {
            // If clicking on own piece, reselect
            if (piece?.Color == myColor)
            {
                selectedRow = row;
                selectedCol = col;
                validMoves = GetValidMovesForPiece(row, col);
                StateHasChanged();
                return;
            }
            
            // Try to move
            if (game.MakeMove(selectedRow, selectedCol, row, col))
            {
                lastMove = (selectedRow, selectedCol, row, col);
                selectedRow = -1;
                selectedCol = -1;
                validMoves.Clear();
                StateHasChanged();
                
                // AI's turn
                if (game.HasAI && !game.IsGameOver && game.IsAITurn())
                {
                    aiThinking = true;
                    StateHasChanged();
                    
                    _ = Task.Run(async () =>
                    {
                        await Task.Delay(200);
                        await InvokeAsync(() =>
                        {
                            if (game != null)
                            {
                                var result = game.MakeAIMoveWithPosition();
                                if (result.HasValue && result.Value.success)
                                {
                                    lastMove = (result.Value.fromRow, result.Value.fromCol, result.Value.toRow, result.Value.toCol);
                                }
                            }
                            aiThinking = false;
                            StateHasChanged();
                        });
                    });
                }
            }
            else
            {
                selectedRow = -1;
                selectedCol = -1;
                validMoves.Clear();
                StateHasChanged();
            }
        }
        else
        {
            // Select own piece
            if (piece?.Color == myColor)
            {
                selectedRow = row;
                selectedCol = col;
                validMoves = GetValidMovesForPiece(row, col);
            }
            StateHasChanged();
        }
    }
    
    private List<(int Row, int Col)> GetValidMovesForPiece(int row, int col)
    {
        var moves = new List<(int, int)>();
        if (game == null) return moves;
        
        for (int r = 0; r < 8; r++)
        {
            for (int c = 0; c < 8; c++)
            {
                // Try the move
                var tempPiece = game.GetPiece(r, c);
                var movingPiece = game.GetPiece(row, col);
                if (movingPiece == null) continue;
                
                // Check if target is own piece
                if (tempPiece?.Color == movingPiece.Color) continue;
                
                if (game.MakeMove(row, col, r, c))
                {
                    moves.Add((r, c));
                    // Undo by resetting... this is hacky but works for display
                    // Better: use validator directly
                }
            }
        }
        
        // Better approach: use validator directly
        return GetValidMovesFromValidator(row, col);
    }
    
    private List<(int Row, int Col)> GetValidMovesFromValidator(int row, int col)
    {
        var moves = new List<(int, int)>();
        if (game == null) return moves;
        
        var myColor = game.IsWhiteTurn ? PieceColor.White : PieceColor.Black;
        var validator = new ChessValidator();
        
        for (int r = 0; r < 8; r++)
        {
            for (int c = 0; c < 8; c++)
            {
                var move = new ChessMove(new Position(row, col), new Position(r, c));
                if (validator.IsValidMove(game.Board, move, myColor))
                {
                    // Check if move leaves king in check
                    if (!WouldBeInCheck(game.Board, move, myColor))
                    {
                        moves.Add((r, c));
                    }
                }
            }
        }
        
        return moves;
    }
    
    private bool WouldBeInCheck(ChessBoard board, ChessMove move, PieceColor color)
    {
        var piece = board.GetPiece(move.From.Row, move.From.Column);
        var captured = board.GetPiece(move.To.Row, move.To.Column);
        
        board.Cells[move.To.Row, move.To.Column] = piece;
        board.Cells[move.From.Row, move.From.Column] = null;
        
        bool inCheck = new ChessValidator().IsInCheck(board, color);
        
        board.Cells[move.From.Row, move.From.Column] = piece;
        board.Cells[move.To.Row, move.To.Column] = captured;
        
        return inCheck;
    }
    
    private async void StartGame()
    {
        Console.WriteLine($"[StartGame] Called. AIIsWhite={game?.AIIsWhite}, CurrentColor={game?.CurrentColor}");
        _aiFirstMoveDone = false;
        game?.StartGame();
        Console.WriteLine($"[StartGame] After StartGame. AIIsWhite={game?.AIIsWhite}, CurrentColor={game?.CurrentColor}, IsPlaying={game?.IsPlaying}");
        _isPaused = false;
        selectedRow = -1;
        selectedCol = -1;
        lastMove = (-1, -1, -1, -1);
        validMoves.Clear();
        StateHasChanged();
        
        // Trigger AI first move
        await Task.Delay(300);
        await TriggerAIFirstMove();
    }
    
    private void TogglePause()
    {
        if (_isPaused) game?.ResumeGame();
        else game?.PauseGame();
        _isPaused = !_isPaused;
        StateHasChanged();
    }
    
    private async void ResetGame()
    {
        _aiFirstMoveDone = false;
        CreateGame();
        _isPaused = false;
        StateHasChanged();
        
        // Trigger AI first move after reset
        await Task.Delay(300);
        await TriggerAIFirstMove();
    }
    
    private async Task TriggerAIFirstMove()
    {
        Console.WriteLine($"[AI] TriggerAIFirstMove called");
        Console.WriteLine($"[AI] _aiFirstMoveDone={_aiFirstMoveDone}, game={game != null}, HasAI={game?.HasAI}, IsPlaying={game?.IsPlaying}, IsAITurn={game?.IsAITurn()}, AIIsWhite={game?.AIIsWhite}, CurrentColor={game?.CurrentColor}");
        
        if (_aiFirstMoveDone || game == null || !game.HasAI || !game.IsPlaying)
        {
            Console.WriteLine($"[AI] Early exit: _aiFirstMoveDone={_aiFirstMoveDone}, game={game != null}, HasAI={game?.HasAI}, IsPlaying={game?.IsPlaying}");
            return;
        }
        
        if (game.IsAITurn())
        {
            _aiFirstMoveDone = true;
            aiThinking = true;
            StateHasChanged();
            Console.WriteLine($"[AI] Starting AI move...");
            
            await Task.Delay(200);
            
            await InvokeAsync(() =>
            {
                if (game != null)
                {
                    Console.WriteLine($"[AI] Calling MakeAIMoveWithPosition...");
                    var result = game.MakeAIMoveWithPosition();
                    Console.WriteLine($"[AI] Result: {result?.success}, from=({result?.fromRow},{result?.fromCol}), to=({result?.toRow},{result?.toCol})");
                    if (result.HasValue && result.Value.success)
                    {
                        lastMove = (result.Value.fromRow, result.Value.fromCol, result.Value.toRow, result.Value.toCol);
                    }
                }
                aiThinking = false;
                StateHasChanged();
                Console.WriteLine($"[AI] AI move complete");
            });
        }
        else
        {
            Console.WriteLine($"[AI] Not AI's turn. CurrentColor={game.CurrentColor}, AIIsWhite={game.AIIsWhite}");
        }
    }
    
    private void SetMode(bool ai)
    {
        useAI = ai;
        CreateGame();
        _isPaused = false;
        StateHasChanged();
    }
    
    private void SetDifficulty(int depth)
    {
        _aiDepth = depth;
        CreateGame();
        _isPaused = false;
        StateHasChanged();
    }
    
    public void Dispose() => GameService.OnStateChanged -= HandleStateChanged;
}
