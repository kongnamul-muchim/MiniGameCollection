@page "/gomoku"
@inject IGameStateService GameService
@implements IDisposable

<PageTitle>Gomoku</PageTitle>

<h1>Gomoku</h1>

@if (game != null)
{
    <div class="game-container">
        <div class="game-info">
            <span>Current: @(game.IsBlackTurn ? "Black" : "White")</span>
            @if (game.Logic.IsGameOver)
            {
                <span>Winner: @(game.Logic.Winner == 1 ? "Black" : (game.Logic.Winner == 2 ? "White" : "Draw"))</span>
            }
        </div>
        
        <div class="gomoku-board">
            @for (int r = 0; r < game.Board.Size; r++)
            {
                <div class="gomoku-row">
                    @for (int c = 0; c < game.Board.Size; c++)
                    {
                        var stone = game.Board.GetCell(r, c);
                        var isLastMove = game.LastMove?.Row == r && game.LastMove?.Column == c;
                        
                        <div class="gomoku-cell @(isLastMove ? "last-move" : "")"
                             @onclick="@(() => PlaceStone(r, c))">
                            @if (stone == 1)
                            {
                                <div class="stone stone-black"></div>
                            }
                            else if (stone == 2)
                            {
                                <div class="stone stone-white"></div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
        
        <div class="game-controls">
            @if (!game.IsPlaying)
            {
                <button class="btn btn-primary" @onclick="StartGame">Start Game</button>
            }
            else
            {
                <button class="btn btn-secondary" @onclick="TogglePause">@(_isPaused ? "Resume" : "Pause")</button>
                <button class="btn btn-danger" @onclick="ResetGame">Reset</button>
            }
        </div>
        
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="game-message">@message</div>
        }
    </div>
}
else
{
    <p>Loading game...</p>
}

@code {
    private GomokuGame? game;
    private bool _isPaused = false;
    private string? message;
    
    protected override void OnInitialized()
    {
        var validator = new Gomoku.Logic.GomokuValidator();
        var logic = new Gomoku.Logic.GomokuLogic(validator);
        game = new GomokuGame(logic);
        GameService.StartGame(game);
        GameService.OnStateChanged += HandleStateChanged;
    }
    
    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }
    
    private void PlaceStone(int row, int col)
    {
        if (!game?.IsPlaying ?? true || _isPaused || game.Logic.IsGameOver) return;
        
        var result = game.PlaceStone(row, col);
        StateHasChanged();
    }
    
    private void StartGame()
    {
        game?.StartGame();
        message = null;
        _isPaused = false;
        StateHasChanged();
    }
    
    private void TogglePause()
    {
        if (_isPaused)
            game?.ResumeGame();
        else
            game?.PauseGame();
        
        _isPaused = !_isPaused;
        StateHasChanged();
    }
    
    private void ResetGame()
    {
        game?.ResetGame();
        message = null;
        _isPaused = false;
        StateHasChanged();
    }
    
    public void Dispose()
    {
        GameService.OnStateChanged -= HandleStateChanged;
    }
}
