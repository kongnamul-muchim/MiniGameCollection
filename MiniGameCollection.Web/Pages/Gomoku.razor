@page "/gomoku"
@inject IGameStateService GameService
@implements IDisposable
@using Games.Gomoku
@using Games.Gomoku.Logic
@using Games.Gomoku.Models

<PageTitle>Gomoku</PageTitle>
<h1>Gomoku</h1>

<div class="game-container">
    @if (game != null && game.Board != null)
    {
        <div class="game-info">
            <span>Turn: <strong>@(game.IsBlackTurn ? "Black ●" : "White ○")</strong></span>
            @if (aiThinking)
            {
                <span class="ai-status">AI thinking...</span>
            }
            @if (game.HasAI)
            {
                <span>Mode: <strong>vs AI (@game.AIDifficulty)</strong></span>
            }
            else
            {
                <span>Mode: <strong>2 Players</strong></span>
            }
        </div>

        @if (game.IsGameOver && game.Winner.HasValue)
        {
            <div class="game-message winner">
                @(game.Winner == 1 ? "Black ● Wins!" : "White ○ Wins!")
            </div>
        }

        <div class="gomoku-board">
            @for (int r = 0; r < game.Board.Size; r++)
            {
                var row = r; // Capture variable
               <div class="gomoku-row">
                    @for (int c = 0; c < game.Board.Size; c++)
                    {
                        var col = c; // Capture variable
                        var stone = game.Board.GetCell(row, col);
                        var isLastMove = lastMove.Row == row && lastMove.Col == col;
                        <div class="gomoku-cell @(isLastMove ? "last-move" : "")" @onclick="() => Place(row, col)">
                            @if (stone == 1)
                            {
                                <div class="stone stone-black"></div>
                            }
                            else if (stone == 2)
                            {
                                <div class="stone stone-white"></div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="game-controls">
            @if (!game.IsPlaying)
            {
                <button class="btn btn-primary" @onclick="Start">Start Game</button>
            }
            else
            {
                <button class="btn btn-secondary" @onclick="Pause">@(_paused ? "Resume" : "Pause")</button>
                <button class="btn btn-danger" @onclick="Reset">Reset</button>
            }
        </div>

        <div class="mode-selector">
            <span>Game Mode:</span>
            <button class="mode-btn @(!useAI ? "active" : "")" @onclick="@(() => SetMode(false))">2 Players</button>
            <button class="mode-btn @(useAI ? "active" : "")" @onclick="@(() => SetMode(true))">vs AI</button>
        </div>

        @if (useAI)
        {
<div class="difficulty-selector">
            <span>AI Level:</span>
            <button class="diff-btn @(_aiDepth == 1 ? "active" : "")" @onclick="@(() => SetDifficulty(1))">Easy</button>
            <button class="diff-btn @(_aiDepth == 2 ? "active" : "")" @onclick="@(() => SetDifficulty(2))">Normal</button>
            <button class="diff-btn @(_aiDepth == 3 ? "active" : "")" @onclick="@(() => SetDifficulty(3))">Hard</button>
        </div>
        }
    }
    else
    {
        <p>Loading...</p>
    }
</div>

@code {
    private GomokuGame? game;
    private bool _paused = false;
    private bool useAI = true;
    private int _aiDepth = 3;
    private (int Row, int Col) lastMove = (-1, -1);
    private bool aiThinking = false;

    protected override void OnInitialized()
    {
        CreateGame();
        GameService.OnStateChanged += StateChanged;
    }

    private void CreateGame()
    {
        if (useAI)
        {
            game = GomokuGame.CreateWithAI(_aiDepth);
        }
        else
        {
            var validator = new GomokuValidator();
            var logic = new GomokuLogic(validator);
            game = new GomokuGame(logic);
        }
        lastMove = (-1, -1);
        GameService.StartGame(game);
        game.StartGame();
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);

    private void Place(int row, int col)
    {
        if (game == null || !game.IsPlaying || _paused)
            return;

        // Player's turn (Black)
        if (!game.IsBlackTurn && game.HasAI)
            return; // Wait for AI

        if (game.PlaceStone(row, col))
        {
            lastMove = (row, col);
            StateHasChanged();

            // AI's turn (White)
            if (game.HasAI && !game.IsGameOver && !game.IsBlackTurn)
            {
                aiThinking = true;
                StateHasChanged();
                
                _ = Task.Run(async () =>
                {
                    await Task.Delay(100); // Small delay for UX
                    await InvokeAsync(() =>
                    {
                        if (game != null)
                        {
                            var result = game.MakeAIMoveWithPosition();
                            if (result.HasValue && result.Value.success)
                            {
                                lastMove = (result.Value.row, result.Value.col);
                            }
                        }
                        aiThinking = false;
                        StateHasChanged();
                    });
                });
            }
        }
    }

    private void Start()
    {
        game?.StartGame();
        _paused = false;
        lastMove = (-1, -1);
        StateHasChanged();
    }

    private void Pause()
    {
        if (_paused)
            game?.ResumeGame();
        else
            game?.PauseGame();
        _paused = !_paused;
        StateHasChanged();
    }

    private void Reset()
    {
        CreateGame();
        _paused = false;
        StateHasChanged();
    }

    private void SetMode(bool ai)
    {
        useAI = ai;
        CreateGame();
        _paused = false;
        StateHasChanged();
    }

    private void SetDifficulty(int depth)
    {
        _aiDepth = depth;
        CreateGame();
        _paused = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        GameService.OnStateChanged -= StateChanged;
    }
}