@page "/gomoku"
@inject IGameStateService GameService
@implements IDisposable

<PageTitle>Gomoku</PageTitle>
<h1>Gomoku</h1>

<div class="game-container">
@if (game != null && game.Board != null)
{
    <div class="game-info"><span>Turn: @(game.IsBlackTurn ? "Black" : "White")</span></div>
    <div class="gomoku-board">
    @for (int r = 0; r < game.Board.Size; r++)
    {
        <div class="gomoku-row">
        @for (int c = 0; c < game.Board.Size; c++)
        {
            var stone = game.Board.GetCell(r, c);
            <div class="gomoku-cell" @onclick="@(()=>Place(r,c))">
            @if(stone==1){<div class="stone stone-black"></div>}
            else if(stone==2){<div class="stone stone-white"></div>}
            </div>
        }
        </div>
    }
    </div>
    <div class="game-controls">
    @if(!game.IsPlaying){<button class="btn btn-primary" @onclick="Start">Start Game</button>}
    else{<button class="btn btn-secondary" @onclick="Pause">@(_p?"Resume":"Pause")</button> <button class="btn btn-danger" @onclick="Res">Reset</button>}
    </div>
} else { <p>Loading...</p> }
</div>

@code {
    private Games.Gomoku.GomokuGame? game;
    private bool _p=false;
    protected override void OnInitialized()
    {
        var val=new Games.Gomoku.Logic.GomokuValidator();
        var logic=new Games.Gomoku.Logic.GomokuLogic(val);
        game=new Games.Gomoku.GomokuGame(logic);
        GameService.StartGame(game);
        GameService.OnStateChanged+=SC;
        // Auto-start game on page enter
        game.StartGame();
    }
    private void SC()=>InvokeAsync(StateHasChanged);
    private void Place(int r,int c){if(!(game?.IsPlaying??false)||_p)return;game.PlaceStone(r,c);StateHasChanged();}
    private void Start(){game?.StartGame();_p=false;StateHasChanged();}
    private void Pause(){if(_p)game?.ResumeGame();else game?.PauseGame();_p=!_p;StateHasChanged();}
    private void Res(){game?.ResetGame();_p=false;StateHasChanged();}
    public void Dispose()=>GameService.OnStateChanged-=SC;
}
