@page "/pattern-memory"
@inject IGameStateService GameService
@implements IDisposable

<PageTitle>Pattern Memory</PageTitle>

<h1>Pattern Memory</h1>

<div class="game-container">
    @if (game != null)
    {
        <div class="game-info">
            <span>Level: @currentLevel</span>
            <span>Score: @currentScore</span>
        </div>
        
        <div class="pattern-grid">
            @for (int i = 0; i < 3; i++)
            {
                for (int j = 0; j < 3; j++)
                {
                    var index = i * 3 + j;
                    <button class="pattern-tile @(IsHighlighted(index) ? "highlighted" : "")"
                            @onclick="@(() => HandleTileClick(index))"
                            disabled="@(isShowingPattern || !game.IsPlaying)">
                    </button>
                }
            }
        </div>
        
        <div class="game-controls">
            @if (!game.IsPlaying)
            {
                <button class="btn btn-primary" @onclick="StartGame">Start Game</button>
            }
            else
            {
                <button class="btn btn-secondary" @onclick="TogglePause">@(_isPaused ? "Resume" : "Pause")</button>
                <button class="btn btn-danger" @onclick="ResetGame">Reset</button>
            }
        </div>
        
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="game-message">@message</div>
        }
    }
    else
    {
        <p>Loading game...</p>
    }
</div>

@code {
    private PatternMemoryGame? game;
    private int currentLevel = 1;
    private int currentScore = 0;
    private bool isShowingPattern = false;
    private bool _isPaused = false;
    private string? message;
    private List<int> currentPattern = new();
    private List<int> shownPattern = new();
    private int playerStep = 0;
    
    protected override void OnInitialized()
    {
        var generator = new PatternGenerator(new Random());
        var logic = new PatternMemoryLogic(generator);
        game = new PatternMemoryGame(logic);
        GameService.StartGame(game);
        GameService.OnStateChanged += HandleStateChanged;
        // Auto-start game on page enter
        StartGame();
    }
    
    private void HandleStateChanged() => InvokeAsync(StateHasChanged);
    
    private async void StartGame()
    {
        game?.StartGame();
        message = "Watch the pattern...";
        isShowingPattern = true;
        currentPattern.Clear();
        AddToPattern();
        await ShowPattern();
    }
    
    private void AddToPattern()
    {
        var rnd = new Random();
        currentPattern.Add(rnd.Next(9));
    }
    
    private async Task ShowPattern()
    {
        isShowingPattern = true;
        shownPattern.Clear();
        foreach (var idx in currentPattern)
        {
            shownPattern.Add(idx);
            StateHasChanged();
            await Task.Delay(600);
            shownPattern.Clear();
            StateHasChanged();
            await Task.Delay(200);
        }
        isShowingPattern = false;
        playerStep = 0;
        message = "Your turn!";
        StateHasChanged();
    }
    
    private void TogglePause()
    {
        if (_isPaused) game?.ResumeGame();
        else game?.PauseGame();
        _isPaused = !_isPaused;
        StateHasChanged();
    }
    
    private void ResetGame()
    {
        game?.ResetGame();
        currentLevel = 1;
        currentScore = 0;
        message = null;
        currentPattern.Clear();
        shownPattern.Clear();
        StateHasChanged();
    }
    
    private bool IsHighlighted(int index) => shownPattern.Contains(index);
    
    private void HandleTileClick(int index)
    {
        if (isShowingPattern || !game.IsPlaying || playerStep >= currentPattern.Count) return;
        
        if (index == currentPattern[playerStep])
        {
            playerStep++;
            if (playerStep >= currentPattern.Count)
            {
                currentScore += 10;
                currentLevel++;
                message = "Good! Next level...";
                isShowingPattern = true;
                StateHasChanged();
                Task.Delay(1000).ContinueWith(_ => InvokeAsync(async () => {
                    AddToPattern();
                    await ShowPattern();
                }));
            }
            else
            {
                message = $"Correct! ({playerStep}/{currentPattern.Count})";
                StateHasChanged();
            }
        }
        else
        {
            message = "Wrong! Try again.";
            currentScore = Math.Max(0, currentScore - 5);
            playerStep = 0;
            StateHasChanged();
        }
    }
    
    public void Dispose() => GameService.OnStateChanged -= HandleStateChanged;
}
